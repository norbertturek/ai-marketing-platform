# =============================================================================
# Klucze używane w projekcie (canonical list)
# =============================================================================
# Wymagane: DATABASE_URL, JWT_ACCESS_SECRET, JWT_REFRESH_SECRET
# Opcjonalne: PORT, CORS_ORIGIN, JWT_*_TTL_SECONDS, BCRYPT_ROUNDS,
#             RUNWARE_API_KEY, OPENAI_API_KEY, R2_* (do mediów)
# =============================================================================

DATABASE_URL="postgresql://postgres:postgres@localhost:5432/marketing?schema=public"
PORT=3000

# CORS — set to your frontend URL in production (e.g. https://web-xxx.railway.app)
CORS_ORIGIN=*

# JWT — generate strong random secrets for production
JWT_ACCESS_SECRET=dev-jwt-access-secret-change-me
JWT_REFRESH_SECRET=dev-jwt-refresh-secret-change-me
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=604800

# Bcrypt
BCRYPT_ROUNDS=12

# AI Content Generation
RUNWARE_API_KEY=         # From https://my.runware.ai/
OPENAI_API_KEY=         # From https://platform.openai.com/

# Cloudflare R2 (S3-compatible) — for storing post media
# Checklist: (1) Create bucket in Cloudflare → R2 → Create bucket (name = R2_BUCKET_NAME)
#            (2) Create API token: R2 → Manage R2 API Tokens → Create → Object Read & Write
#            (3) R2_ACCOUNT_ID = Cloudflare dashboard → R2 → Overview (right sidebar)
R2_ACCOUNT_ID=          # Your Cloudflare account ID (e.g. 32-char hex)
R2_ACCESS_KEY_ID=       # From R2 → Manage R2 API Tokens (Access Key ID)
R2_SECRET_ACCESS_KEY=   # Same token (Secret Access Key)
R2_BUCKET_NAME=ai-marketing-content-platform   # Must match bucket name in Cloudflare exactly
# Public URL: R2 → bucket → Settings → Public Development URL → Enable, then: pnpm r2:public-url
R2_PUBLIC_URL=         # e.g. https://pub-xxxxx.r2.dev (no trailing slash)
