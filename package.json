{
  "name": "ai-marketing-content-platform",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:api": "pnpm --filter api dev",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down",
    "r2:public-url": "wrangler r2 bucket dev-url get ai-marketing-content-platform",
    "r2:public-url:enable": "wrangler r2 bucket dev-url enable ai-marketing-content-platform",
    "prepare": "husky"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "husky": "^9.1.7",
    "prettier": "^3.7.4",
    "turbo": "^2.8.11",
    "typescript": "5.9.2",
    "wrangler": "^4.71.0"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  }
}
